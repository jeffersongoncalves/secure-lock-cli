{
    "name": "jeffersongoncalves/secure-lock-cli",
    "description": "CLI tool to audit project dependencies (Composer & npm) for known vulnerabilities and tell whether an available update actually leaves the vulnerable range.",
    "keywords": ["cli", "security", "audit", "composer", "npm", "supply-chain", "advisories", "vulnerabilities"],
    "homepage": "https://github.com/jeffersongoncalves/secure-lock-cli",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Jefferson Goncalves",
            "email": "jeffersongoncalves@users.noreply.github.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "composer/semver": "^3.4",
        "guzzlehttp/guzzle": "^7.10",
        "illuminate/http": "^12.0"
    },
    "require-dev": {
        "laravel-zero/framework": "^12.0",
        "laravel/pint": "^1.25",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^3.8|^4.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "build": ["php secure-lock app:build secure-lock"],
        "lint": "./vendor/bin/pint",
        "test:lint": "./vendor/bin/pint --test",
        "test:unit": "./vendor/bin/pest --parallel",
        "test": [
            "@test:unit",
            "@test:lint"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["builds/secure-lock"]
}
